# CODEOWNERS — Echoes of Slumber (Hidden Dream Studio)
# Defines automatic PR reviewers based on file type/location.
# Uses TEAM handles (@HiddenDreamStudio/<team>) so any team member with
# write access is a valid reviewer. Individual handles only where the user
# has write access (org owner / maintainer).
# Docs: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# ──────────────────────────────────────────────
# DEFAULT: Leads team reviews everything by default
# ──────────────────────────────────────────────
*                           @HiddenDreamStudio/leads-reviewers

# ──────────────────────────────────────────────
# ENGINE / CODE (.cpp, .h) → Dev Engineers team + Lead Dev
# ──────────────────────────────────────────────
/src/                       @TheUnrealZaka @HiddenDreamStudio/dev-engineers
/include/                   @TheUnrealZaka @HiddenDreamStudio/dev-engineers
*.cpp                       @TheUnrealZaka @HiddenDreamStudio/dev-engineers
*.h                         @TheUnrealZaka @HiddenDreamStudio/dev-engineers

# ──────────────────────────────────────────────
# ART ASSETS → Art Creators team
# ──────────────────────────────────────────────
/assets/textures/           @HiddenDreamStudio/art-creators
/assets/sprites/            @HiddenDreamStudio/art-creators
*.png                       @HiddenDreamStudio/art-creators
*.jpg                       @HiddenDreamStudio/art-creators
*.bmp                       @HiddenDreamStudio/art-creators

# ──────────────────────────────────────────────
# AUDIO → Art Creators team (no dedicated audio lead)
# ──────────────────────────────────────────────
/assets/audio/              @HiddenDreamStudio/art-creators

# ──────────────────────────────────────────────
# LEVEL DESIGN (Tiled maps) → Design & Production team
# ──────────────────────────────────────────────
/assets/maps/               @HiddenDreamStudio/design-and-prod
*.tmx                       @HiddenDreamStudio/design-and-prod
*.tsx                       @HiddenDreamStudio/design-and-prod

# ──────────────────────────────────────────────
# BUILD SYSTEM & CI → Lead Dev + Leads
# ──────────────────────────────────────────────
/build/                     @TheUnrealZaka @HiddenDreamStudio/leads-reviewers
/.github/                   @TheUnrealZaka @HiddenDreamStudio/leads-reviewers
*.bat                       @TheUnrealZaka
*.lua                       @TheUnrealZaka

# ──────────────────────────────────────────────
# DOCUMENTATION → Producers team
# ──────────────────────────────────────────────
*.md                        @HiddenDreamStudio/producers
/docs/                      @HiddenDreamStudio/producers

# ──────────────────────────────────────────────
# CONFIG → Lead Dev
# ──────────────────────────────────────────────
*.xml                       @TheUnrealZaka
.gitignore                  @TheUnrealZaka
